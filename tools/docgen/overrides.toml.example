# overrides.toml — project-specific prose overrides.
#
# Copy this file to the parent tools/ directory:
#   cp tools/docgen/overrides.toml.example tools/overrides.toml
#
# tools/overrides.toml is gitignored — never commit it.
#
# Keys match the header path relative to include/, without extension,
# using forward slashes. Example:
#   "vision/implementation/detection/obstacle_detector"
#
# Within each section:
#   __overview__           = overview paragraph (Markdown)
#   __constructor__        = constructor description
#   method_name            = description for that method
#   method_name.param_name = description for a specific parameter
#
# Methods already handled by naming conventions (get_*/set_*,
# on_setup, on_teardown, on_update, setup, teardown, …) do NOT
# need entries here unless you want to override the generated text.
#
# Namespace overviews can be provided under:
#
# [__namespaces__]
# core = "Overview for acs::core"
# utility = "Overview for acs::utility"
# vision = "Overview for acs::vision"
#
# ---------------------------------------------------------------------------
# Example:
# ---------------------------------------------------------------------------
#
# ["mynamespace/implementation/my_class"]
# __overview__    = "Does X and Y."
# __constructor__ = "Creates a my class with the given name."
# my_method       = "Performs the thing."
# "my_method.param_name" = "The value to use."
